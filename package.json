	"license": "MPL-2.0",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/parser": "^8.59.3",
		"esbuild": "0.17.3",
		"eslint": "^9.0.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.4.5",
		"typescript-eslint": "^8.0.0"
	},
	"dependencies": {
		"argon2-browser": "1.18.0",
		"tweetnacl": "1.0.3"
